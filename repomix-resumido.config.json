{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-output-resumido.xml",
    "style": "xml",
    "parsableStyle": false,
    "compress": false,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": false,
    "topFilesLength": 20,
    "git": {
      "sortByChanges": true,
      "includeDiffs": false,
      "includeLogs": false
    }
  },
  "include": [
    "**/*"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "MICROCONTROLADORES-STM32/Drivers/**",
      "MICROCONTROLADORES-STM32/Middlewares/**",
      "MICROCONTROLADORES-STM32/Core/Startup/**",
      "MICROCONTROLADORES-STM32/.cproject",
      "MICROCONTROLADORES-STM32/.project",
      "MICROCONTROLADORES-STM32/.mxproject",
      "MICROCONTROLADORES-STM32/.settings/**",
      "MICROCONTROLADORES-STM32/**/LICENSE.txt"
    ]
  },
  "security": {
    "enableSecurityCheck": false
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
